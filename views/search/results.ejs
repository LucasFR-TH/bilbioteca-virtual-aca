<!-- views/search/results.ejs -->
<div class="page-header">
  <h1 class="page-title">
    <% if (query) { %>Resultados para "<%= query %>"<% } else { %>Búsqueda avanzada<% } %>
  </h1>
  <span class="result-count"><%= totalFound %> documento<%= totalFound !== 1 ? 's' : '' %></span>
</div>

<form method="GET" action="/search" class="filter-bar">
  <input type="text" name="q" value="<%= query %>" placeholder="Buscar..." class="filter-input" autofocus />
  <select name="category" class="filter-select">
    <option value="">Todas las categorías</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= filters.category === cat.id ? 'selected' : '' %>><%= cat.icon %> <%= cat.name %></option>
    <% }) %>
  </select>
  <button type="submit" class="btn-filter">Buscar</button>
  <a href="/search" class="btn-clear">✕</a>
</form>

<% if (results.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">🔍</div>
    <p>No se encontraron resultados para "<%= query %>".</p>
    <a href="/documents" class="btn-secondary">Ver todos los documentos</a>
  </div>
<% } else { %>
  <div class="doc-grid">
    <% results.forEach(doc => { %>
      <%- include('../documents/_card', { doc }) %>
    <% }) %>
  </div>
<% } %>
