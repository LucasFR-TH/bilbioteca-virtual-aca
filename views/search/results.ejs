<%# views/search/results.ejs — Resultados de búsqueda %>

<!-- Header -->
<div class="search-results-header">
  <h1 class="search-query-display">
    Resultados para <span>"<%= query %>"</span>
  </h1>
  <p class="search-meta">
    <%= results.length %> documento<%= results.length !== 1 ? 's' : '' %> encontrado<%= results.length !== 1 ? 's' : '' %>
  </p>
</div>

<!-- Filtros de búsqueda avanzada -->
<form method="GET" action="/search" class="search-filters-bar">
  <input
    type="text"
    name="q"
    value="<%= query %>"
    placeholder="Buscar…"
    class="filter-input"
    autocomplete="off"
  />

  <select name="category" class="filter-select">
    <option value="">Todas las categorías</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>"
        <%= filters && filters.category === cat.id ? 'selected' : '' %>>
        <%= cat.icon %> <%= cat.name %>
      </option>
    <% }) %>
  </select>

  <select name="type" class="filter-select">
    <option value="">Todos los tipos</option>
    <% ['PDF','DOCX','XLSX','PPTX','DOC','XLS'].forEach(t => { %>
      <option value="<%= t %>"
        <%= filters && filters.type === t ? 'selected' : '' %>><%= t %></option>
    <% }) %>
  </select>

  <button type="submit" class="btn-filter">🔍 Buscar</button>
  <a href="/search" class="btn-clear">✕ Limpiar</a>
</form>

<!-- Resultados -->
<% if (results.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">🔍</div>
    <p>No se encontraron resultados para "<%= query %>".</p>
    <p style="font-size:13px; color:var(--text4); margin-top:8px;">
      Probá con otra palabra clave o revisá los filtros.
    </p>
    <a href="/" class="btn-primary" style="margin-top:16px;">← Volver al inicio</a>
  </div>
<% } else { %>
  <div class="doc-grid">
    <% results.forEach(doc => { %>
      <%- include('../documents/_card', { doc }) %>
    <% }) %>
  </div>
<% } %>
