<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Inicio' %> — Biblioteca Digital</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<div class="app-shell">

  <!-- ══ SIDEBAR ════════════════════════════════════════════ -->
  <aside class="sidebar" id="sidebar">

    <!-- Logo -->
    <div class="sidebar-logo">
      <div class="logo-icon">📚</div>
      <div>
        <div class="logo-title">Biblioteca</div>
        <div class="logo-sub">Digital Archive</div>
      </div>
    </div>

    <!-- Stats rápidas -->
    <% if (typeof stats !== 'undefined' && stats) { %>
    <div class="sidebar-stats">
      <div class="stat-chip">
        <span class="stat-num"><%= stats.active %></span>
        <span class="stat-label">Docs</span>
      </div>
      <div class="stat-chip">
        <span class="stat-num"><%= stats.totalDownloads %></span>
        <span class="stat-label">Descargas</span>
      </div>
    </div>
    <% } %>

    <!-- Navegación -->
    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= currentPath === '/' ? 'active' : '' %>">
        <span>🏠</span> Inicio
      </a>
      <a href="/documents" class="nav-item <%= currentPath.startsWith('/documents') ? 'active' : '' %>">
        <span>📄</span> Documentos
      </a>
      <a href="/folders" class="nav-item <%= currentPath.startsWith('/folders') ? 'active' : '' %>">
        <span>📁</span> Carpetas
      </a>
      <a href="/categories" class="nav-item <%= currentPath.startsWith('/categories') ? 'active' : '' %>">
        <span>🏷️</span> Categorías
      </a>
      <a href="/search" class="nav-item <%= currentPath.startsWith('/search') ? 'active' : '' %>">
        <span>🔍</span> Búsqueda
      </a>
    </nav>

    <!-- Árbol de carpetas -->
    <% if (typeof folderTree !== 'undefined' && folderTree && folderTree.length > 0) { %>
    <div class="folder-tree">
      <div class="tree-label">Carpetas</div>
      <% folderTree.forEach(folder => { %>
        <div class="tree-root">
          <a href="/folders/<%= folder.id %>" class="tree-node root-node">
            <span class="toggle-arrow">▶</span>
            <span><%= folder.icon %></span>
            <span class="node-name"><%= folder.name %></span>
            <span class="node-dot" style="background:<%= folder.color %>"></span>
          </a>
          <% if (folder.children && folder.children.length > 0) { %>
          <div class="tree-children">
            <% folder.children.forEach(child => { %>
              <a href="/folders/<%= child.id %>" class="tree-node child-node">
                <span><%= child.icon %></span>
                <span class="node-name"><%= child.name %></span>
              </a>
            <% }) %>
          </div>
          <% } %>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Footer sidebar -->
    <div class="sidebar-footer">
      <a href="/documents/new" class="btn-new-doc">＋ Nuevo Documento</a>
    </div>

  </aside>

  <!-- ══ CONTENIDO PRINCIPAL ════════════════════════════════ -->
  <div class="layout">

    <!-- Topbar -->
    <header class="topbar">
      <button class="sidebar-toggle" aria-label="Menú">☰</button>

      <form action="/search" method="GET" class="search-form" role="search">
        <span class="search-icon">🔍</span>
        <input
          type="text"
          name="q"
          placeholder="Buscar documentos… (presioná /)"
          class="search-input"
          autocomplete="off"
          value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
        />
        <button type="submit" class="search-btn">Buscar</button>
      </form>

      <a href="/api/documents" class="topbar-api-link" target="_blank" rel="noopener">⚡ API</a>
    </header>

    <!-- Contenido -->
    <main class="main-content" id="main">
      <%- body %>
    </main>

  </div><!-- /.layout -->

</div><!-- /.app-shell -->

<script src="/js/main.js"></script>
</body>
</html>
