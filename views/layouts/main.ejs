<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Inicio' %> — Biblioteca Digital</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<div class="app-shell">

  <!-- ══ SIDEBAR ════════════════════════════════════════════ -->
  <aside class="sidebar" id="sidebar">

    <!-- Logo -->
    <div class="sidebar-logo">
      <div class="logo-icon">📚</div>
      <div>
        <div class="logo-title">Biblioteca</div>
        <div class="logo-sub">Digital Archive</div>
      </div>
    </div>

    <!-- Navegación principal -->
    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= currentPath === '/' ? 'active' : '' %>">
        <span>🏠</span> Inicio
      </a>
      <a href="/secciones" class="nav-item <%= currentPath.startsWith('/secciones') ? 'active' : '' %>">
        <span>📂</span> Secciones
      </a>
      <a href="/search" class="nav-item <%= currentPath.startsWith('/search') ? 'active' : '' %>">
        <span>🔍</span> Búsqueda
      </a>
    </nav>

    <!-- ── Secciones en el sidebar ─────────────────────────── -->
    <div class="folder-tree">
      <div class="tree-label">Secciones</div>

      <a href="/secciones/actividades"
         class="tree-node root-node <%= currentPath.includes('/actividades') ? 'tree-node--active' : '' %>">
        <span>🏃</span><span class="node-name">Actividades</span>
        <span class="node-dot" style="background:#4CAF50"></span>
      </a>

      <a href="/secciones/area-adultos"
         class="tree-node root-node <%= currentPath.includes('/area-adultos') ? 'tree-node--active' : '' %>">
        <span>👨</span><span class="node-name">Área Adultos</span>
        <span class="node-dot" style="background:#9E9E9E"></span>
      </a>

      <a href="/secciones/area-aspirantes"
         class="tree-node root-node <%= currentPath.includes('/area-aspirantes') ? 'tree-node--active' : '' %>">
        <span>🌱</span><span class="node-name">Área Aspirantes</span>
        <span class="node-dot" style="background:#66BB6A"></span>
      </a>

      <a href="/secciones/area-joven"
         class="tree-node root-node <%= currentPath.includes('/area-joven') ? 'tree-node--active' : '' %>">
        <span>🧑</span><span class="node-name">Área Joven</span>
        <span class="node-dot" style="background:#42A5F5"></span>
      </a>

      <a href="/secciones/area-sectores"
         class="tree-node root-node <%= currentPath.includes('/area-sectores') ? 'tree-node--active' : '' %>">
        <span>🗂️</span><span class="node-name">Área Sectores</span>
        <span class="node-dot" style="background:#EF5350"></span>
      </a>

      <a href="/secciones/formacion"
         class="tree-node root-node <%= currentPath.includes('/formacion') ? 'tree-node--active' : '' %>">
        <span>📚</span><span class="node-name">Formación</span>
        <span class="node-dot" style="background:#FF7043"></span>
      </a>

      <a href="/secciones/recreacion"
         class="tree-node root-node <%= currentPath.includes('/recreacion') ? 'tree-node--active' : '' %>">
        <span>🎨</span><span class="node-name">Recreación</span>
        <span class="node-dot" style="background:#AB47BC"></span>
      </a>

      <a href="/secciones/semana-santa"
         class="tree-node root-node <%= currentPath.includes('/semana-santa') ? 'tree-node--active' : '' %>">
        <span>✝️</span><span class="node-name">Semana Santa</span>
        <span class="node-dot" style="background:#FFA726"></span>
      </a>
    </div>

  </aside>

  <!-- ══ CONTENIDO PRINCIPAL ════════════════════════════════ -->
  <div class="layout">

    <!-- Topbar -->
    <header class="topbar">
      <button class="sidebar-toggle" aria-label="Menú">☰</button>

      <!-- Buscador rápido en topbar -->
      <form action="/search" method="GET" class="search-form" role="search">
        <span class="search-icon">🔍</span>
        <input
          type="text"
          name="q"
          placeholder="Buscar documentos… (presioná /)"
          class="search-input"
          autocomplete="off"
          value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
        />
        <button type="submit" class="search-btn">Buscar</button>
      </form>
    </header>

    <!-- Contenido -->
    <main class="main-content" id="main">
      <%- body %>
    </main>

  </div><!-- /.layout -->

</div><!-- /.app-shell -->

<script src="/js/main.js"></script>
</body>
</html>
