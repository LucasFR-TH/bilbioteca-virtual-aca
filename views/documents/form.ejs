<!-- views/documents/form.ejs -->
<div class="form-page">
  <div class="form-header">
    <h1 class="page-title"><%= title %></h1>
    <a href="/documents" class="btn-back">← Volver</a>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="alert-error">
      <% errors.forEach(e => { %><p>⚠️ <%= e %></p><% }) %>
    </div>
  <% } %>

  <form action="<%= formAction %>" method="<%= formMethod %>" class="doc-form">

    <div class="form-grid">
      <!-- Título -->
      <div class="form-group full">
        <label class="form-label">Título *</label>
        <input type="text" name="title" class="form-input" required
               value="<%= doc ? doc.title : '' %>" placeholder="Título del documento" />
      </div>

      <!-- Descripción -->
      <div class="form-group full">
        <label class="form-label">Descripción</label>
        <textarea name="description" class="form-textarea" rows="3"
                  placeholder="Breve descripción del contenido..."><%= doc ? doc.description : '' %></textarea>
      </div>

      <!-- Categoría -->
      <div class="form-group">
        <label class="form-label">Categoría *</label>
        <select name="categoryId" class="form-select" required>
          <option value="">Seleccionar categoría...</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= doc && doc.categoryId === cat.id ? 'selected' : '' %>>
              <%= cat.icon %> <%= cat.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Carpeta -->
      <div class="form-group">
        <label class="form-label">Carpeta *</label>
        <select name="folderId" class="form-select" required>
          <option value="">Seleccionar carpeta...</option>
          <% folders.forEach(f => { %>
            <option value="<%= f.id %>" <%= doc && doc.folderId === f.id ? 'selected' : '' %>>
              <%= f.icon %> <%= f.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Tipo de archivo -->
      <div class="form-group">
        <label class="form-label">Tipo de archivo</label>
        <select name="fileType" class="form-select">
          <% fileTypes.forEach(ft => { %>
            <option value="<%= ft %>" <%= doc && doc.fileType === ft ? 'selected' : '' %>><%= ft %></option>
          <% }) %>
        </select>
      </div>

      <!-- Google Drive ID -->
      <div class="form-group">
        <label class="form-label">ID de Google Drive *</label>
        <input type="text" name="driveId" class="form-input"
               value="<%= doc ? doc.driveId : '' %>"
               placeholder="1BxiMVs0XRA5nFMdK..." />
        <small class="form-hint">Encontralo en: drive.google.com/file/d/<strong>[ESTE_ID]</strong>/view</small>
      </div>

      <!-- Tags -->
      <div class="form-group full">
        <label class="form-label">Etiquetas</label>
        <input type="text" name="tags" class="form-input"
               value="<%= doc && doc.tags ? doc.tags.join(', ') : '' %>"
               placeholder="reglamento, 2024, normativa (separadas por coma)" />
      </div>

      <!-- Destacado -->
      <div class="form-group">
        <label class="form-check">
          <input type="checkbox" name="featured" <%= doc && doc.featured ? 'checked' : '' %> />
          <span>Marcar como destacado</span>
        </label>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary btn-submit">
        <%= doc && doc.id ? '💾 Guardar cambios' : '✚ Crear documento' %>
      </button>
      <a href="/documents" class="btn-cancel">Cancelar</a>
    </div>
  </form>
</div>
