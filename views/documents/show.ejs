<%# views/documents/show.ejs — Detalle + preview de Drive %>

<div class="doc-show-layout">

  <!-- ── Panel izquierdo: Preview Drive ─────────────────── -->
  <div class="doc-preview-panel">
    <div class="preview-header">
      <span class="preview-label">📄 Vista previa · Google Drive</span>
      <div style="display:flex; gap:10px; align-items:center;">
        <span
          class="drive-badge"
          data-copy="<%= doc.driveUrl %>"
          style="cursor:pointer;"
          title="Copiar link">
          🔗 Copiar link
        </span>
        <a href="<%= doc.driveUrl %>" target="_blank" rel="noopener" class="preview-open-link">
          Abrir en Drive ↗
        </a>
      </div>
    </div>

    <div class="preview-frame-wrap">
      <!-- Spinner mientras carga el iframe -->
      <div class="preview-loading">
        <div class="preview-spinner"></div>
        <span>Cargando desde Google Drive…</span>
      </div>

      <iframe
        src="<%= doc.previewUrl %>"
        class="preview-iframe"
        allow="autoplay"
        title="Vista previa: <%= doc.title %>"
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <!-- ── Panel derecho: Metadatos ───────────────────────── -->
  <aside class="doc-meta-panel">

    <!-- Badge tipo de archivo -->
    <div class="meta-type-badge"
      style="background:<%= doc.fileTypeMeta.color %>1a; border-color:<%= doc.fileTypeMeta.color %>44; color:<%= doc.fileTypeMeta.color %>">
      <%= doc.fileTypeMeta.icon %> <%= doc.fileType %>
    </div>

    <h1 class="meta-title"><%= doc.title %></h1>
    <p class="meta-desc"><%= doc.description %></p>

    <!-- Acciones principales -->
    <div class="meta-actions">
      <a href="/documents/<%= doc.id %>/download" class="btn-dl-primary">
        ⬇ Descargar desde Drive
      </a>
      <a href="<%= doc.driveUrl %>" target="_blank" rel="noopener" class="btn-dl-secondary">
        🔗 Ver en Google Drive
      </a>
    </div>

    <!-- Detalles -->
    <div class="meta-section">
      <div class="meta-section-title">Detalles</div>
      <div class="meta-table">

        <% if (doc.category) { %>
        <div class="meta-row">
          <span class="meta-key">Categoría</span>
          <a href="/categories/<%= doc.categoryId %>" class="meta-val"
            style="color:<%= doc.category.color %>">
            <%= doc.category.icon %> <%= doc.category.name %>
          </a>
        </div>
        <% } %>

        <% if (doc.folder) { %>
        <div class="meta-row">
          <span class="meta-key">Carpeta</span>
          <a href="/folders/<%= doc.folderId %>" class="meta-val">
            <%= doc.folder.icon %> <%= doc.folder.breadcrumbPath || doc.folder.name %>
          </a>
        </div>
        <% } %>

        <div class="meta-row">
          <span class="meta-key">Tipo</span>
          <span class="meta-val"><%= doc.fileType %></span>
        </div>

        <div class="meta-row">
          <span class="meta-key">Descargas</span>
          <span class="meta-val"><%= doc.downloadCount %></span>
        </div>

        <div class="meta-row">
          <span class="meta-key">Agregado</span>
          <span class="meta-val"><%= doc.formattedDate %></span>
        </div>

      </div>
    </div>

    <!-- Tags -->
    <% if (doc.tags && doc.tags.length > 0) { %>
    <div class="meta-section">
      <div class="meta-section-title">Etiquetas</div>
      <div class="meta-tags">
        <% doc.tags.forEach(tag => { %>
          <a href="/search?q=<%= tag %>" class="meta-tag">#<%= tag %></a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Acciones de gestión -->
    <div class="meta-section" style="margin-top:auto;">
      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <a href="/documents/<%= doc.id %>/edit" class="btn-secondary" style="font-size:11px; padding:7px 12px;">
          ✏️ Editar
        </a>
        <form action="/documents/<%= doc.id %>?_method=DELETE" method="POST" style="display:inline;">
          <button type="submit" class="btn-danger" style="font-size:11px; padding:7px 12px;"
            data-confirm="¿Archivar este documento?">
            🗄 Archivar
          </button>
        </form>
      </div>
    </div>

  </aside>

</div>
