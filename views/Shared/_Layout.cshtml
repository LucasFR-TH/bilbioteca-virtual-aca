@* views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Biblioteca Digital</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/biblioteca.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="app-shell">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-logo">
            <div class="logo-icon">📚</div>
            <div>
                <div class="logo-title">Biblioteca</div>
                <div class="logo-sub">Digital Archive</div>
            </div>
        </div>

        <!-- Nav principal -->
        <nav class="sidebar-nav">
            <a href="@Url.Action("Index","Home")"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span>🏠</span> Inicio
            </a>
            <a href="@Url.Action("Index","Sections")"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sections" ? "active" : "")">
                <span>📂</span> Secciones
            </a>
            <a href="@Url.Action("Index","Search")"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Search" ? "active" : "")">
                <span>🔍</span> Búsqueda
            </a>
        </nav>

        <!-- Árbol de secciones -->
        <div class="folder-tree">
            <div class="tree-label">Secciones</div>

            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var currentSectionId = ViewContext.RouteData.Values["id"]?.ToString() ?? "";

                var sectionLinks = new[]
                {
                    ("actividades",     "🏃",  "Actividades",     "#4CAF50"),
                    ("area-adultos",    "👨",  "Área Adultos",    "#9E9E9E"),
                    ("area-aspirantes", "🌱",  "Área Aspirantes", "#66BB6A"),
                    ("area-joven",      "🧑",  "Área Joven",      "#42A5F5"),
                    ("area-sectores",   "🗂️", "Área Sectores",   "#EF5350"),
                    ("formacion",       "📚",  "Formación",       "#FF7043"),
                    ("recreacion",      "🎨",  "Recreación",      "#AB47BC"),
                    ("semana-santa",    "✝️",  "Semana Santa",    "#FFA726"),
                };
            }

            @foreach (var (id, emoji, label, color) in sectionLinks)
            {
                var isActive = ctrl == "Sections" && currentSectionId == id;
                <a href="@Url.Action("Show","Sections", new { id })"
                   class="tree-node root-node @(isActive ? "tree-node--active" : "")">
                    <span>@emoji</span>
                    <span class="node-name">@label</span>
                    <span class="node-dot" style="background:@color"></span>
                </a>
            }
        </div>

    </aside>

    <!-- ══ LAYOUT PRINCIPAL ══════════════════════════════════ -->
    <div class="layout">

        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Menú">☰</button>

            <form asp-controller="Search" asp-action="Index" method="get" class="search-form" role="search">
                <span class="search-icon">🔍</span>
                <input type="text" name="q"
                       placeholder="Buscar documentos… (presioná /)"
                       class="search-input" autocomplete="off"
                       value="@ViewBag.SearchQuery" />
                <button type="submit" class="search-btn">Buscar</button>
            </form>
        </header>

        <main class="main-content" id="main" role="main">
            @RenderBody()
        </main>

    </div>

</div>

<script src="~/js/biblioteca.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
