<!-- views/errors/500.ejs -->
<div class="error-page">
  <div class="error-code">500</div>
  <h1 class="error-title">Error del servidor</h1>
  <p><%= message %></p>
  <% if (stack) { %><pre class="error-stack"><%= stack %></pre><% } %>
  <a href="/" class="btn-primary">← Volver al inicio</a>
</div>
