<%# views/errors/500.ejs %>
<div class="error-page">
  <div class="error-code">500</div>
  <h1 class="error-title">Error del servidor</h1>
  <p class="error-desc">Ocurrió un problema inesperado. Por favor intentá de nuevo en unos momentos.</p>
  <% if (process.env.NODE_ENV === 'development' && typeof error !== 'undefined') { %>
    <pre style="background:var(--bg3); border:1px solid var(--border2); border-radius:var(--radius); padding:16px; font-family:var(--font-mono); font-size:12px; color:var(--danger); text-align:left; max-width:600px; overflow:auto; margin-top:16px; white-space:pre-wrap;"><%= error.message %>\n<%= error.stack %></pre>
  <% } %>
  <a href="/" class="btn-primary" style="margin-top:16px;">🏠 Ir al inicio</a>
</div>
